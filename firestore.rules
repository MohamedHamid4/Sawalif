rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== قواعد المستخدمين =====
    match /users/{userId} {
      // قراءة: أي مستخدم مسجّل (للبحث وعرض الملفات الشخصية)
      allow read: if request.auth != null;

      // إنشاء/تحديث/حذف: صاحب الحساب فقط
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ===== قواعد أسماء المستخدمين (لضمان التفرّد) =====
    match /usernames/{username} {
      // قراءة: عامة - يحتاجها فحص التوفر أثناء التسجيل (قبل المصادقة)
      // الوثيقة لا تحتوي على بيانات حساسة (uid + reservedAt فقط)
      allow read: if true;

      // إنشاء: المستخدم نفسه فقط
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;

      // حذف: مالك الحجز فقط (عند حذف الحساب)
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;

      // ممنوع التعديل
      allow update: if false;
    }

    // ===== قواعد الحالات (Stories) - تنتهي خلال 24 ساعة =====
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // أي مستخدم مصادق عليه يستطيع تعليم الحالة كمشاهَدة (يُحدّث viewedBy فقط)
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ===== قواعد البلاغات (للإشراف فقط) =====
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.reporterId;
      allow read, update, delete: if false;
    }

    // ===== قواعد المحادثات =====
    match /chats/{chatId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // تحديث: أي مشارك (للتفاعلات، حالة الكتابة، علامات الحذف...)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ===== الرسائل =====
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // المرسل فقط يمكنه حذف رسالته
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.senderId;
      }
    }
  }
}
